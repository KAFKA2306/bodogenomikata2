# RuleScribe Games v2
# =====================

# Required: Google Generative Language API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Specific Gemini Model (Defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: BGG API settings
# Required as of late 2025: BGG Access Token (Bearer Token)
# Get yours at https://boardgamegeek.com/applications
BGG_ACCESS_TOKEN=your_bgg_access_token_here
# BGG_TIMEOUT=30
